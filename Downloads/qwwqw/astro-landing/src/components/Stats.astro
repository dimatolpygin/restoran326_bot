---
const stats = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#666" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    number: '2M+',
    label: 'пользователей',
    desc: 'по всему миру',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#666" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/></svg>`,
    number: '50+',
    label: 'AI-моделей',
    desc: 'GPT, Claude, Gemini и другие',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#666" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
    number: '99.9%',
    label: 'uptime',
    desc: 'гарантированная доступность',
  },
];
---

<section
  style="
    background: #111111;
    border-top: 1px solid #2A2A2A;
    border-bottom: 1px solid #2A2A2A;
    padding: 96px 24px;
  "
>
  <div style="max-width: 1100px; margin: 0 auto;">
    <div
      style="
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2px;
      "
    >
      {
        stats.map((stat, i) => (
          <div
            data-reveal
            style={`
              padding: 48px 40px;
              text-align: center;
              background: #111111;
              ${i < stats.length - 1 ? 'border-right: 1px solid #2A2A2A;' : ''}
              position: relative;
            `}
          >
            <div
              style="
                background: #111111;
                border-radius: 16px;
                padding: 32px;
                box-shadow:
                  inset 4px 4px 12px rgba(0,0,0,0.5),
                  inset -2px -2px 6px rgba(255,255,255,0.04),
                  4px 4px 16px rgba(0,0,0,0.4),
                  -2px -2px 8px rgba(255,255,255,0.03);
                border: 1px solid #2A2A2A;
              "
            >
              <span style="margin-bottom: 16px; display: block;" set:html={stat.icon} />
              <div
                style="
                  font-size: 48px;
                  font-weight: 800;
                  letter-spacing: -2px;
                  color: #FFFFFF;
                  line-height: 1;
                  margin-bottom: 8px;
                "
              >
                {stat.number}
              </div>
              <div style="font-size: 14px; color: #A1A1AA;">{stat.label}</div>
              <div style="font-size: 12px; color: #444; margin-top: 6px;">{stat.desc}</div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
