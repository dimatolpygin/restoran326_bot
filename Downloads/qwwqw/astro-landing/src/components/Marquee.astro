---
const models = [
  { name: 'GPT-4o', icon: 'bot' },
  { name: 'Claude 3.5 Sonnet', icon: 'brain' },
  { name: 'Gemini 1.5 Pro', icon: 'gem' },
  { name: 'Mistral Large', icon: 'wind' },
  { name: 'Llama 3.1 405B', icon: 'layers' },
  { name: 'GPT-4 Turbo', icon: 'zap' },
  { name: 'Claude 3 Opus', icon: 'sparkles' },
  { name: 'Gemini Ultra', icon: 'globe' },
  { name: 'Grok 2', icon: 'code-2' },
  { name: 'Perplexity', icon: 'search' },
  { name: 'DeepSeek V3', icon: 'microscope' },
  { name: 'Command R+', icon: 'terminal' },
];

// Duplicate for seamless loop
const allModels = [...models, ...models];

const iconMap: Record<string, string> = {
