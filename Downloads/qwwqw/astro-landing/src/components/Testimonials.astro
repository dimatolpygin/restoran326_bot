---
const testimonials = [
  {
    text: 'Переключение между моделями прямо в диалоге — это killer feature. Спрашиваю у GPT-4, затем проверяю у Claude, нахожу лучший ответ. Экономит кучу времени каждый день.',
    initials: 'АМ',
    name: 'Алексей М.',
    role: 'CTO, TechStart',
  },
  {
    text: 'Использую для учёбы каждый день. GPT-4 объясняет математику по-своему, Claude — по-другому. Наконец нахожу то объяснение, которое доходит до меня. Жалею, что не нашла раньше.',
    initials: 'МК',
    name: 'Мария К.',
    role: 'Студентка, МГУ',
  },
  {
    text: 'Подключил API за пять минут, документация понятная. Теперь все наши внутренние инструменты работают через NeuralChat. Один ключ — все модели. Это то, что я искал.',
    initials: 'ИС',
    name: 'Игорь С.',
    role: 'Фрилансер, fullstack',
  },
];
---

<section
  style="
    background: #111111;
    border-top: 1px solid #2A2A2A;
    border-bottom: 1px solid #2A2A2A;
    padding: 96px 24px;
  "
>
  <div style="max-width: 1100px; margin: 0 auto;">
    <div
      style="
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 1.8px;
        text-transform: uppercase;
        color: #555;
        margin-bottom: 16px;
      "
    >
      Отзывы
    </div>
    <div
      style="
        font-size: clamp(28px, 3.5vw, 48px);
        font-weight: 800;
        letter-spacing: -1.5px;
        line-height: 1.1;
        margin-bottom: 16px;
        background: linear-gradient(180deg, #FFF 0%, #888 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      "
    >
      Два миллиона<br />довольных пользователей
    </div>
    <p style="font-size: 16px; color: #A1A1AA; max-width: 500px; line-height: 1.6;">
      Вот что говорят те, кто перешёл на NeuralChat.
    </p>

    <div
      style="
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-top: 56px;
      "
    >
      {
        testimonials.map((t) => (
          <div
            data-reveal
            style="
              background: #111111;
              border: 1px solid #2A2A2A;
              border-radius: 20px;
              padding: 32px;
              position: relative;
              overflow: hidden;
              box-shadow:
                6px 6px 20px rgba(0,0,0,0.5),
                -2px -2px 8px rgba(255,255,255,0.03),
                inset 0 1px 0 rgba(255,255,255,0.05);
            "
          >
            <div
              style="
                font-size: 32px;
                color: #333;
                line-height: 1;
                margin-bottom: 16px;
                font-family: Georgia, serif;
              "
            >
              "
            </div>
            <p style="font-size: 14px; color: #A1A1AA; line-height: 1.65; margin-bottom: 24px;">
              {t.text}
            </p>
            <div style="display: flex; align-items: center; gap: 12px;">
              <div
                style="
                  width: 36px; height: 36px;
                  border-radius: 50%;
                  background: linear-gradient(135deg, #2a2a2a, #1a1a1a);
                  border: 1px solid #333;
                  display: flex; align-items: center; justify-content: center;
                  font-size: 13px;
                  font-weight: 600;
                  color: #A1A1AA;
                  box-shadow: 2px 2px 8px rgba(0,0,0,0.4);
                "
              >
                {t.initials}
              </div>
              <div>
                <div style="font-size: 14px; font-weight: 600; letter-spacing: -0.2px;">{t.name}</div>
                <div style="font-size: 12px; color: #555; margin-top: 1px;">{t.role}</div>
              </div>
              <div style="margin-left: auto; font-size: 12px; color: #555; letter-spacing: 1px;">
                ★★★★★
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
