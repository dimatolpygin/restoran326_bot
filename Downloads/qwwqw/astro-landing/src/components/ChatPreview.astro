---
---

<section
  style="
    background: #111111;
    border-top: 1px solid #2A2A2A;
    border-bottom: 1px solid #2A2A2A;
    padding: 96px 24px;
  "
>
  <div style="max-width: 1100px; margin: 0 auto;">
    <div
      style="
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 64px;
        align-items: center;
      "
    >
      <!-- Left: text -->
      <div data-reveal>
        <div
          style="
            font-size: 12px;
            font-weight: 600;
            letter-spacing: 1.8px;
            text-transform: uppercase;
            color: #555;
            margin-bottom: 16px;
          "
        >
          Интерфейс
        </div>
        <div
          style="
            font-size: clamp(28px, 3.5vw, 48px);
            font-weight: 800;
            letter-spacing: -1.5px;
            line-height: 1.1;
            margin-bottom: 16px;
            background: linear-gradient(180deg, #FFF 0%, #888 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
          "
        >
          Чат, который<br />просто работает
        </div>
        <p style="font-size: 16px; color: #A1A1AA; max-width: 500px; line-height: 1.6; margin-top: 16px;">
          Никаких лишних настроек. Открываешь — и общаешься. Интерфейс создан для продуктивности.
        </p>
        <div style="margin-top: 32px; display: flex; flex-direction: column; gap: 14px;">
          {
            [
              'Markdown, формулы и подсветка кода',
              'Голосовой ввод и ответы',
              'Экспорт диалогов в PDF / MD',
              'Тёмная тема и кастомизация',
            ].map((item) => (
              <div style="display: flex; align-items: center; gap: 12px; font-size: 14px; color: #A1A1AA;">
                <div
                  style="
                    width: 6px; height: 6px;
                    border-radius: 50%;
                    background: #555;
                    flex-shrink: 0;
                  "
                />
                {item}
              </div>
            ))
          }
        </div>
      </div>

      <!-- Right: preview window -->
      <div data-reveal>
        <div
          style="
            background: linear-gradient(145deg, #161616, #101010);
            border: 1px solid #2A2A2A;
            border-radius: 24px;
            overflow: hidden;
            box-shadow:
              10px 10px 40px rgba(0,0,0,0.8),
              -3px -3px 12px rgba(255,255,255,0.04),
              inset 0 1px 0 rgba(255,255,255,0.06);
          "
        >
          <!-- Title bar -->
          <div
            style="
              display: flex;
              align-items: center;
              gap: 8px;
              padding: 16px 20px;
              border-bottom: 1px solid #2A2A2A;
              background: #111;
            "
          >
            <div style="width: 12px; height: 12px; border-radius: 50%; background: #3a1a1a; border: 1px solid #4a2a2a;" />
            <div style="width: 12px; height: 12px; border-radius: 50%; background: #3a3a1a; border: 1px solid #4a4a2a;" />
            <div style="width: 12px; height: 12px; border-radius: 50%; background: #1a3a1a; border: 1px solid #2a4a2a;" />
            <div style="flex: 1; text-align: center; font-size: 12px; color: #444;">NeuralChat — GPT-4o</div>
          </div>

          <!-- Body -->
          <div style="padding: 24px 20px; min-height: 320px;">
            <!-- User msg -->
            <div style="margin-bottom: 14px; display: flex; gap: 10px; flex-direction: row-reverse;">
              <div
                style="
                  max-width: 78%;
                  padding: 10px 14px;
                  border-radius: 14px 14px 4px 14px;
                  font-size: 13px;
                  line-height: 1.55;
                  background: #2a2a2a;
                  color: #FFFFFF;
                  box-shadow: 2px 2px 8px rgba(0,0,0,0.4), -1px -1px 4px rgba(255,255,255,0.04);
                "
              >
                Напиши функцию на Python для быстрой сортировки
              </div>
            </div>

            <!-- AI msg -->
            <div style="margin-bottom: 14px; display: flex; gap: 10px;">
              <div
                style="
                  width: 28px; height: 28px; min-width: 28px;
                  border-radius: 50%;
                  background: linear-gradient(135deg, #2a2a2a, #161616);
                  border: 1px solid #333;
                  display: flex; align-items: center; justify-content: center;
                  font-size: 12px;
                "
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#888" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
              </div>
              <div
                style="
                  max-width: 78%;
                  padding: 10px 14px;
                  border-radius: 14px 14px 14px 4px;
                  font-family: 'Courier New', monospace;
                  font-size: 12px;
                  line-height: 1.7;
                  color: #aaa;
                  background: #161616;
                  border: 1px solid #2A2A2A;
                  box-shadow: 2px 2px 8px rgba(0,0,0,0.4), -1px -1px 4px rgba(255,255,255,0.04);
                "
              >
                <span style="color:#666">def</span> <span style="color:#ddd">quicksort</span>(arr):<br />
                &nbsp;&nbsp;<span style="color:#666">if</span> len(arr) &lt;= 1:<br />
                &nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#666">return</span> arr<br />
                &nbsp;&nbsp;pivot = arr[len(arr) // 2]<br />
                &nbsp;&nbsp;left = [x <span style="color:#666">for</span> x <span style="color:#666">in</span> arr <span style="color:#666">if</span> x &lt; pivot]<br />
                &nbsp;&nbsp;<span style="color:#666">return</span> quicksort(left) + [pivot] + ...
              </div>
            </div>

            <!-- User msg 2 -->
            <div style="margin-bottom: 14px; display: flex; gap: 10px; flex-direction: row-reverse;">
              <div
                style="
                  max-width: 78%;
                  padding: 10px 14px;
                  border-radius: 14px 14px 4px 14px;
                  font-size: 13px;
                  line-height: 1.55;
                  background: #2a2a2a;
                  color: #FFFFFF;
                  box-shadow: 2px 2px 8px rgba(0,0,0,0.4), -1px -1px 4px rgba(255,255,255,0.04);
                "
              >
                Добавь аннотации типов
              </div>
            </div>

            <!-- Typing -->
            <div style="display: flex; align-items: center; gap: 5px; margin-top: 8px; padding-left: 38px;">
              <div class="typing-dot" />
              <div class="typing-dot" />
              <div class="typing-dot" />
            </div>

            <!-- Input bar -->
            <div
              style="
                margin-top: 24px;
                display: flex;
                align-items: center;
                gap: 10px;
                background: #161616;
                border: 1px solid #2A2A2A;
                border-radius: 12px;
                padding: 10px 14px;
                box-shadow: inset 2px 2px 6px rgba(0,0,0,0.5), inset -1px -1px 4px rgba(255,255,255,0.03);
              "
            >
              <span style="flex: 1; font-size: 13px; color: #444;">Продолжить диалог...</span>
              <div
                style="
                  width: 30px; height: 30px;
                  border-radius: 8px;
                  background: linear-gradient(135deg, #333, #222);
                  border: 1px solid #3a3a3a;
                  display: flex; align-items: center; justify-content: center;
                  font-size: 13px;
                  box-shadow: 2px 2px 6px rgba(0,0,0,0.4), -1px -1px 3px rgba(255,255,255,0.05);
                "
              >↑</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
